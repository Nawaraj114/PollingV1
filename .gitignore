# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (the example is intentionally safe to commit)
.env*
!.env.example

# credentials and recovery material
recovery-codes.txt
*recovery-codes*.txt

# vercel
.vercel

# Supabase local state
/supabase/.branches/
/supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
